[agent]
# Project-level config is loaded from .zx-code/config.toml.
# User-level config is loaded from ~/.zx-code/config.toml.
# CLI options override both.

[agent.model]
name = "openai/gpt-5.4-mini"
fallback_models = "openai/gpt-5.5"
reasoning_effort = "" # supported values depend on the model/provider, e.g. "low", "medium", "high"
max_iterations = 30
timeout_s = 300.0
stream = true
render_markdown = true
markdown_streaming = true

[[agent.model.profiles]]
name = "primary"
model = "openai/gpt-5.4-mini"
api_key_env = "OPENAI_API_KEY"
# reasoning_effort = "medium"

[[agent.model.profiles]]
name = "backup"
model = "openai/gpt-5.5"
api_key_env = "OPENAI_API_KEY"
# reasoning_effort = "high"

# For an OpenAI-compatible Chat Completions endpoint, set base_url here.
# If the endpoint only supports /responses, config alone is not enough.
# [[agent.model.profiles]]
# name = "custom"
# model = "openai/gpt-5.4-mini"
# api_key_env = "CUSTOM_API_KEY"
# extra_kwargs = { base_url = "https://example.com/v1" }

[agent.context]
max_tokens = 128000
keep_recent = 15
tool_result_max_chars = 6000
compact_model = ""

[agent.state]
session_id = "default"
data_dir = ".agent"
memory_path = ".memory/MEMORY.md"
enable_memory = true
enable_skills = true
skills_dir = "skills"
enable_todos = true
enable_tasks = true
tasks_dir = ".tasks"

[agent.permissions]
default = "allow"
rules_path = ""

[agent.permissions.tools]
# bash = "ask"
# edit = "allow"

[agent.channel]
name = "cli"
account_id = "local"

[agent.channel.telegram]
token = ""
offset = 0
timeout_s = 30
allowed_chats = ""
text_coalesce_s = 1.0
media_group_coalesce_s = 0.5

[agent.routing]
agent_id = "default"
default_agent_id = "default"
force_agent_id = ""
dm_scope = "per-account-channel-peer"

[agent.delivery]
max_attempts = 5
base_delay_s = 1.0
max_delay_s = 300.0
jitter_s = 1.0
daemon_interval_s = 1.0

[agent.scheduling]
heartbeat_enabled = false
heartbeat_interval_s = 300.0
heartbeat_min_idle_s = 30.0
heartbeat_channel = ""
heartbeat_to = ""
heartbeat_prompt = "Heartbeat check. Reply HEARTBEAT_OK if no user-facing update is needed."
heartbeat_sentinel = "HEARTBEAT_OK"
cron_jobs_path = ""

[agent.subagents]
enabled = true
max_depth = 1

[agent.worktree]
isolation_enabled = false
dir = ".agent/worktrees"

[agent.code_context]
enabled = false
path = ".agent/code-context/chroma"
snapshot_dir = ".agent/code-context/snapshots"
collection = "agent_code_context"
top_k = 5
max_result_chars = 4000
max_total_chars = 12000

[agent.debug]
log_enabled = false
log_path = ".agent/debug.jsonl"

[agent.extensions]
hooks_path = ""
plugin_dirs = []

# Optional MCP server example.
# [[agent.extensions.mcp_servers]]
# name = "filesystem"
# command = "python"
# args = ["./mcp_servers/filesystem_server.py"]
# env = { TOKEN = "env-or-placeholder-only" }
